// ============================================================
// ERP Sublimación — Prisma Schema
// ============================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ============================================================
// MULTITENANCY
// ============================================================

model Company {
  id        String   @id @default(cuid())
  name      String
  settings  Json     @default("{}")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  users        User[]
  categories   Category[]
  products     Product[]
  clients      Client[]
  suppliers    Supplier[]
  quotes       Quote[]
  sales        Sale[]
  purchases    Purchase[]
  transactions Transaction[]
  accountsRecv AccountReceivable[]
  accountsPay  AccountPayable[]

  @@map("companies")
}

// ============================================================
// AUTH
// ============================================================

enum UserRole {
  ADMIN
  SELLER
}

model User {
  id           String   @id @default(cuid())
  companyId    String   @map("company_id")
  name         String
  email        String
  passwordHash String   @map("password_hash")
  role         UserRole @default(SELLER)
  active       Boolean  @default(true)
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  company   Company @relation(fields: [companyId], references: [id])
  sales     Sale[]
  quotes    Quote[]
  purchases Purchase[]

  @@unique([companyId, email])
  @@map("users")
}

// ============================================================
// PRODUCTOS E INVENTARIO
// ============================================================

model Category {
  id        String   @id @default(cuid())
  companyId String   @map("company_id")
  name      String
  createdAt DateTime @default(now()) @map("created_at")

  company  Company   @relation(fields: [companyId], references: [id])
  products Product[]

  @@unique([companyId, name])
  @@map("categories")
}

model Product {
  id         String   @id @default(cuid())
  companyId  String   @map("company_id")
  categoryId String?  @map("category_id")
  name       String
  sku        String?
  description String?
  cost       Decimal  @db.Decimal(12, 2)
  price      Decimal  @db.Decimal(12, 2)
  stock      Decimal  @default(0) @db.Decimal(12, 3)
  minStock   Decimal  @default(0) @map("min_stock") @db.Decimal(12, 3)
  unit       String   @default("un")
  active     Boolean  @default(true)
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  company        Company         @relation(fields: [companyId], references: [id])
  category       Category?       @relation(fields: [categoryId], references: [id])
  stockMovements StockMovement[]
  quoteItems     QuoteItem[]
  saleItems      SaleItem[]
  purchaseItems  PurchaseItem[]

  @@unique([companyId, sku])
  @@map("products")
}

enum MovementType {
  IN   // entrada: compra, ajuste positivo
  OUT  // salida: venta, ajuste negativo
}

enum MovementRefType {
  SALE
  PURCHASE
  ADJUSTMENT
}

model StockMovement {
  id        String          @id @default(cuid())
  companyId String          @map("company_id")
  productId String          @map("product_id")
  type      MovementType
  quantity  Decimal         @db.Decimal(12, 3)
  refType   MovementRefType @map("ref_type")
  refId     String?         @map("ref_id")
  notes     String?
  date      DateTime        @default(now())
  createdAt DateTime        @default(now()) @map("created_at")

  product Product @relation(fields: [productId], references: [id])

  @@index([companyId, productId])
  @@index([companyId, date])
  @@map("stock_movements")
}

// ============================================================
// CLIENTES
// ============================================================

model Client {
  id        String   @id @default(cuid())
  companyId String   @map("company_id")
  name      String
  email     String?
  phone     String?
  address   String?
  taxId     String?  @map("tax_id")  // CUIT/DNI
  notes     String?
  active    Boolean  @default(true)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  company      Company             @relation(fields: [companyId], references: [id])
  quotes       Quote[]
  sales        Sale[]
  accountsRecv AccountReceivable[]

  @@index([companyId, name])
  @@map("clients")
}

// ============================================================
// PROVEEDORES
// ============================================================

model Supplier {
  id        String   @id @default(cuid())
  companyId String   @map("company_id")
  name      String
  email     String?
  phone     String?
  address   String?
  taxId     String?  @map("tax_id")
  notes     String?
  active    Boolean  @default(true)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  company     Company          @relation(fields: [companyId], references: [id])
  purchases   Purchase[]
  accountsPay AccountPayable[]

  @@index([companyId, name])
  @@map("suppliers")
}

// ============================================================
// PRESUPUESTOS
// ============================================================

enum QuoteStatus {
  PENDING   // pendiente
  APPROVED  // aprobado (convertido a venta)
  REJECTED  // rechazado
  EXPIRED   // vencido
}

model Quote {
  id         String      @id @default(cuid())
  companyId  String      @map("company_id")
  clientId   String?     @map("client_id")
  userId     String      @map("user_id")
  number     Int
  date       DateTime    @default(now())
  validUntil DateTime?   @map("valid_until")
  status     QuoteStatus @default(PENDING)
  subtotal   Decimal     @db.Decimal(12, 2)
  discount   Decimal     @default(0) @db.Decimal(12, 2)
  total      Decimal     @db.Decimal(12, 2)
  notes      String?
  createdAt  DateTime    @default(now()) @map("created_at")
  updatedAt  DateTime    @updatedAt @map("updated_at")

  company Company     @relation(fields: [companyId], references: [id])
  client  Client?     @relation(fields: [clientId], references: [id])
  user    User        @relation(fields: [userId], references: [id])
  items   QuoteItem[]
  sale    Sale?

  @@unique([companyId, number])
  @@index([companyId, status])
  @@index([companyId, date])
  @@map("quotes")
}

model QuoteItem {
  id          String  @id @default(cuid())
  quoteId     String  @map("quote_id")
  productId   String? @map("product_id")
  description String
  quantity    Decimal @db.Decimal(12, 3)
  unitPrice   Decimal @map("unit_price") @db.Decimal(12, 2)
  total       Decimal @db.Decimal(12, 2)

  quote   Quote    @relation(fields: [quoteId], references: [id], onDelete: Cascade)
  product Product? @relation(fields: [productId], references: [id])

  @@map("quote_items")
}

// ============================================================
// VENTAS
// ============================================================

enum SaleStatus {
  COMPLETED // completada
  PENDING   // pendiente de pago
  CANCELLED // cancelada
}

enum PaymentMethod {
  CASH         // efectivo
  TRANSFER     // transferencia
  CARD         // tarjeta
  MERCADOPAGO  // MP
  CREDIT       // cuenta corriente (a cobrar)
  OTHER
}

model Sale {
  id            String        @id @default(cuid())
  companyId     String        @map("company_id")
  clientId      String?       @map("client_id")
  userId        String        @map("user_id")
  quoteId       String?       @unique @map("quote_id")
  number        Int
  date          DateTime      @default(now())
  status        SaleStatus    @default(COMPLETED)
  paymentMethod PaymentMethod @map("payment_method")
  subtotal      Decimal       @db.Decimal(12, 2)
  discount      Decimal       @default(0) @db.Decimal(12, 2)
  total         Decimal       @db.Decimal(12, 2)
  notes         String?
  createdAt     DateTime      @default(now()) @map("created_at")
  updatedAt     DateTime      @updatedAt @map("updated_at")

  company     Company             @relation(fields: [companyId], references: [id])
  client      Client?             @relation(fields: [clientId], references: [id])
  user        User                @relation(fields: [userId], references: [id])
  quote       Quote?              @relation(fields: [quoteId], references: [id])
  items       SaleItem[]
  accountRecv AccountReceivable[]
  transaction Transaction[]

  @@unique([companyId, number])
  @@index([companyId, date])
  @@index([companyId, clientId])
  @@map("sales")
}

model SaleItem {
  id          String  @id @default(cuid())
  saleId      String  @map("sale_id")
  productId   String? @map("product_id")
  description String
  quantity    Decimal @db.Decimal(12, 3)
  unitPrice   Decimal @map("unit_price") @db.Decimal(12, 2)
  unitCost    Decimal @map("unit_cost") @db.Decimal(12, 2)
  total       Decimal @db.Decimal(12, 2)

  sale    Sale     @relation(fields: [saleId], references: [id], onDelete: Cascade)
  product Product? @relation(fields: [productId], references: [id])

  @@map("sale_items")
}

// ============================================================
// COMPRAS
// ============================================================

enum PurchaseStatus {
  PENDING   // pendiente de recibir
  RECEIVED  // recibida
  CANCELLED // cancelada
}

model Purchase {
  id         String         @id @default(cuid())
  companyId  String         @map("company_id")
  supplierId String?        @map("supplier_id")
  userId     String         @map("user_id")
  number     Int
  date       DateTime       @default(now())
  status     PurchaseStatus @default(RECEIVED)
  subtotal   Decimal        @db.Decimal(12, 2)
  total      Decimal        @db.Decimal(12, 2)
  notes      String?
  createdAt  DateTime       @default(now()) @map("created_at")
  updatedAt  DateTime       @updatedAt @map("updated_at")

  company     Company          @relation(fields: [companyId], references: [id])
  supplier    Supplier?        @relation(fields: [supplierId], references: [id])
  user        User             @relation(fields: [userId], references: [id])
  items       PurchaseItem[]
  accountsPay AccountPayable[]
  transaction Transaction[]

  @@unique([companyId, number])
  @@index([companyId, date])
  @@map("purchases")
}

model PurchaseItem {
  id          String  @id @default(cuid())
  purchaseId  String  @map("purchase_id")
  productId   String? @map("product_id")
  description String
  quantity    Decimal @db.Decimal(12, 3)
  unitCost    Decimal @map("unit_cost") @db.Decimal(12, 2)
  total       Decimal @db.Decimal(12, 2)

  purchase Purchase @relation(fields: [purchaseId], references: [id], onDelete: Cascade)
  product  Product? @relation(fields: [productId], references: [id])

  @@map("purchase_items")
}

// ============================================================
// FINANZAS
// ============================================================

enum TransactionType {
  INCOME  // ingreso
  EXPENSE // egreso
}

enum TransactionRefType {
  SALE
  PURCHASE
  ACCOUNT_RECEIVABLE
  ACCOUNT_PAYABLE
  MANUAL
}

model Transaction {
  id          String             @id @default(cuid())
  companyId   String             @map("company_id")
  type        TransactionType
  category    String
  amount      Decimal            @db.Decimal(12, 2)
  date        DateTime           @default(now())
  description String
  refType     TransactionRefType @map("ref_type") @default(MANUAL)
  refId       String?            @map("ref_id")
  saleId      String?            @map("sale_id")
  purchaseId  String?            @map("purchase_id")
  createdAt   DateTime           @default(now()) @map("created_at")

  company  Company   @relation(fields: [companyId], references: [id])
  sale     Sale?     @relation(fields: [saleId], references: [id])
  purchase Purchase? @relation(fields: [purchaseId], references: [id])

  @@index([companyId, date])
  @@index([companyId, type])
  @@map("transactions")
}

// ============================================================
// CUENTAS A COBRAR / PAGAR
// ============================================================

enum AccountStatus {
  PENDING // pendiente
  PARTIAL // pago parcial
  PAID    // pagado
}

model AccountReceivable {
  id          String        @id @default(cuid())
  companyId   String        @map("company_id")
  clientId    String        @map("client_id")
  saleId      String        @map("sale_id")
  amount      Decimal       @db.Decimal(12, 2)
  amountPaid  Decimal       @default(0) @map("amount_paid") @db.Decimal(12, 2)
  dueDate     DateTime?     @map("due_date")
  paidAt      DateTime?     @map("paid_at")
  status      AccountStatus @default(PENDING)
  notes       String?
  createdAt   DateTime      @default(now()) @map("created_at")
  updatedAt   DateTime      @updatedAt @map("updated_at")

  company Company @relation(fields: [companyId], references: [id])
  client  Client  @relation(fields: [clientId], references: [id])
  sale    Sale    @relation(fields: [saleId], references: [id])

  @@index([companyId, status])
  @@index([companyId, clientId])
  @@map("accounts_receivable")
}

model AccountPayable {
  id          String        @id @default(cuid())
  companyId   String        @map("company_id")
  supplierId  String        @map("supplier_id")
  purchaseId  String        @map("purchase_id")
  amount      Decimal       @db.Decimal(12, 2)
  amountPaid  Decimal       @default(0) @map("amount_paid") @db.Decimal(12, 2)
  dueDate     DateTime?     @map("due_date")
  paidAt      DateTime?     @map("paid_at")
  status      AccountStatus @default(PENDING)
  notes       String?
  createdAt   DateTime      @default(now()) @map("created_at")
  updatedAt   DateTime      @updatedAt @map("updated_at")

  company  Company  @relation(fields: [companyId], references: [id])
  supplier Supplier @relation(fields: [supplierId], references: [id])
  purchase Purchase @relation(fields: [purchaseId], references: [id])

  @@index([companyId, status])
  @@index([companyId, supplierId])
  @@map("accounts_payable")
}
