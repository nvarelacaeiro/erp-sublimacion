// ============================================================
// ERP Sublimación — Prisma Schema
// ============================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ============================================================
// MULTITENANCY
// ============================================================

enum CompanyPlan {
  TRIAL
  STARTER
  PRO
}

model Company {
  id          String      @id @default(cuid())
  name        String
  slug        String?     @unique  // subdominio: empresa.norde.ar
  plan        CompanyPlan @default(TRIAL)
  trialEndsAt DateTime?   @map("trial_ends_at")
  active      Boolean     @default(true)
  suspended   Boolean     @default(false) // true cuando vence trial o no pagan
  settings    Json        @default("{}")
  createdAt   DateTime    @default(now()) @map("created_at")
  updatedAt   DateTime    @updatedAt @map("updated_at")

  users         User[]
  categories    Category[]
  products      Product[]
  clients       Client[]
  suppliers     Supplier[]
  quotes        Quote[]
  sales         Sale[]
  purchases     Purchase[]
  transactions  Transaction[]
  accountsRecv  AccountReceivable[]
  accountsPay   AccountPayable[]
  requisitions  Requisition[]
  deliveryNotes DeliveryNote[]
  projects      Project[]

  @@map("companies")
}

// ============================================================
// AUTH
// ============================================================

enum UserRole {
  ADMIN
  SELLER
  APPROVER
  REQUESTER
}

model User {
  id           String   @id @default(cuid())
  companyId    String   @map("company_id")
  name         String
  email        String
  passwordHash String   @map("password_hash")
  phone        String?  // WhatsApp del usuario
  role         UserRole @default(SELLER)
  active       Boolean  @default(true)
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  company   Company @relation(fields: [companyId], references: [id])
  sales     Sale[]
  quotes    Quote[]
  purchases Purchase[]
  requisitionsCreated  Requisition[] @relation("RequestedBy")
  requisitionsApproved Requisition[] @relation("ApprovedBy")
  projectsCreated      Project[]

  @@unique([companyId, email])
  @@map("users")
}

// ============================================================
// PRODUCTOS E INVENTARIO
// ============================================================

model Category {
  id        String   @id @default(cuid())
  companyId String   @map("company_id")
  name      String
  createdAt DateTime @default(now()) @map("created_at")

  company  Company   @relation(fields: [companyId], references: [id])
  products Product[]

  @@unique([companyId, name])
  @@map("categories")
}

model Product {
  id          String   @id @default(cuid())
  companyId   String   @map("company_id")
  categoryId  String?  @map("category_id")
  name        String
  sku         String?
  description String?
  cost        Decimal  @db.Decimal(12, 2)
  price       Decimal  @db.Decimal(12, 2)
  stock       Decimal  @default(0) @db.Decimal(12, 3)
  minStock    Decimal  @default(0) @map("min_stock") @db.Decimal(12, 3)
  unit        String    @default("un")
  active      Boolean   @default(true)
  alertSent   Boolean   @default(false) @map("alert_sent")
  alertSentAt DateTime? @map("alert_sent_at")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  company          Company           @relation(fields: [companyId], references: [id])
  category         Category?         @relation(fields: [categoryId], references: [id])
  stockMovements   StockMovement[]
  quoteItems       QuoteItem[]
  saleItems        SaleItem[]
  purchaseItems    PurchaseItem[]
  productItems     ProductItem[]
  pricingRules     PricingRule[]
  requisitionItems RequisitionItem[]

  @@unique([companyId, sku])
  @@map("products")
}

// ── Ítems configurables por producto (extras) ─────────────────
enum ProductItemType {
  QUANTITY // el usuario define cuántas unidades (ej: estampas)
  BOOLEAN  // el usuario activa/desactiva (ej: packaging)
}

model ProductItem {
  id        String          @id @default(cuid())
  productId String          @map("product_id")
  name      String
  cost      Decimal         @db.Decimal(12, 2)
  type      ProductItemType @default(QUANTITY)
  active    Boolean         @default(true)
  createdAt DateTime        @default(now()) @map("created_at")

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@map("product_items")
}

// ── Reglas de precio por escala ───────────────────────────────
model PricingRule {
  id               String  @id @default(cuid())
  productId        String  @map("product_id")
  minQty           Int     @map("min_qty")
  maxQty           Int?    @map("max_qty")   // null = sin límite superior
  marginPercentage Decimal @map("margin_percentage") @db.Decimal(8, 2)

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@map("pricing_rules")
}

enum MovementType {
  IN   // entrada: compra, ajuste positivo
  OUT  // salida: venta, ajuste negativo
}

enum MovementRefType {
  SALE
  PURCHASE
  ADJUSTMENT
}

model StockMovement {
  id        String          @id @default(cuid())
  companyId String          @map("company_id")
  productId String          @map("product_id")
  type      MovementType
  quantity  Decimal         @db.Decimal(12, 3)
  refType   MovementRefType @map("ref_type")
  refId     String?         @map("ref_id")
  notes     String?
  date      DateTime        @default(now())
  createdAt DateTime        @default(now()) @map("created_at")

  product Product @relation(fields: [productId], references: [id])

  @@index([companyId, productId])
  @@index([companyId, date])
  @@map("stock_movements")
}

// ============================================================
// CLIENTES
// ============================================================

model Client {
  id           String   @id @default(cuid())
  companyId    String   @map("company_id")
  name         String
  businessName String?  @map("business_name")
  email        String?
  phone        String?
  address      String?
  taxId        String?  @map("tax_id")
  notes        String?
  active       Boolean  @default(true)
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  company      Company             @relation(fields: [companyId], references: [id])
  quotes       Quote[]
  sales        Sale[]
  accountsRecv AccountReceivable[]

  @@index([companyId, name])
  @@map("clients")
}

// ============================================================
// PROVEEDORES
// ============================================================

model Supplier {
  id        String   @id @default(cuid())
  companyId String   @map("company_id")
  name      String
  email     String?
  phone     String?
  address   String?
  taxId     String?  @map("tax_id")
  notes     String?
  active    Boolean  @default(true)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  company     Company          @relation(fields: [companyId], references: [id])
  purchases   Purchase[]
  accountsPay AccountPayable[]

  @@index([companyId, name])
  @@map("suppliers")
}

// ============================================================
// PRESUPUESTOS
// ============================================================

enum QuoteStatus {
  PENDING
  APPROVED
  REJECTED
  EXPIRED
}

model Quote {
  id         String      @id @default(cuid())
  companyId  String      @map("company_id")
  clientId   String?     @map("client_id")
  userId     String      @map("user_id")
  number     Int
  date       DateTime    @default(now())
  validUntil DateTime?   @map("valid_until")
  status     QuoteStatus @default(PENDING)
  subtotal   Decimal     @db.Decimal(12, 2)
  discount   Decimal     @default(0) @db.Decimal(12, 2)
  total      Decimal     @db.Decimal(12, 2)
  notes      String?
  createdAt  DateTime    @default(now()) @map("created_at")
  updatedAt  DateTime    @updatedAt @map("updated_at")

  company Company     @relation(fields: [companyId], references: [id])
  client  Client?     @relation(fields: [clientId], references: [id])
  user    User        @relation(fields: [userId], references: [id])
  items   QuoteItem[]
  sale    Sale?

  @@unique([companyId, number])
  @@index([companyId, status])
  @@index([companyId, date])
  @@map("quotes")
}

model QuoteItem {
  id          String  @id @default(cuid())
  quoteId     String  @map("quote_id")
  productId   String? @map("product_id")
  description String
  quantity    Decimal @db.Decimal(12, 3)
  unitPrice   Decimal @map("unit_price") @db.Decimal(12, 2)
  total       Decimal @db.Decimal(12, 2)

  quote   Quote    @relation(fields: [quoteId], references: [id], onDelete: Cascade)
  product Product? @relation(fields: [productId], references: [id])

  @@map("quote_items")
}

// ============================================================
// VENTAS
// ============================================================

enum SaleStatus {
  COMPLETED
  PENDING
  CANCELLED
}

enum PaymentMethod {
  CASH
  TRANSFER
  CARD
  MERCADOPAGO
  CREDIT
  OTHER
}

model Sale {
  id            String        @id @default(cuid())
  companyId     String        @map("company_id")
  clientId      String?       @map("client_id")
  userId        String        @map("user_id")
  quoteId       String?       @unique @map("quote_id")
  number        Int
  date          DateTime      @default(now())
  status        SaleStatus    @default(COMPLETED)
  paymentMethod PaymentMethod @map("payment_method")
  subtotal      Decimal       @db.Decimal(12, 2)
  discount      Decimal       @default(0) @db.Decimal(12, 2)
  total         Decimal       @db.Decimal(12, 2)
  notes         String?
  createdAt     DateTime      @default(now()) @map("created_at")
  updatedAt     DateTime      @updatedAt @map("updated_at")

  company       Company             @relation(fields: [companyId], references: [id])
  client        Client?             @relation(fields: [clientId], references: [id])
  user          User                @relation(fields: [userId], references: [id])
  quote         Quote?              @relation(fields: [quoteId], references: [id])
  items         SaleItem[]
  accountRecv   AccountReceivable[]
  transaction   Transaction[]
  deliveryNotes DeliveryNote[]

  @@unique([companyId, number])
  @@index([companyId, date])
  @@index([companyId, clientId])
  @@map("sales")
}

// ── Remito asociado a una venta ───────────────────────────────
model DeliveryNote {
  id        String   @id @default(cuid())
  companyId String   @map("company_id")
  saleId    String   @map("sale_id")
  number    Int
  date      DateTime @default(now())
  notes     String?
  createdAt DateTime @default(now()) @map("created_at")

  company Company @relation(fields: [companyId], references: [id])
  sale    Sale    @relation(fields: [saleId], references: [id], onDelete: Cascade)

  @@unique([companyId, number])
  @@index([companyId, saleId])
  @@map("delivery_notes")
}

model SaleItem {
  id          String  @id @default(cuid())
  saleId      String  @map("sale_id")
  productId   String? @map("product_id")
  description String
  quantity    Decimal @db.Decimal(12, 3)
  unitPrice   Decimal @map("unit_price") @db.Decimal(12, 2)
  unitCost    Decimal @map("unit_cost") @db.Decimal(12, 2)
  total       Decimal @db.Decimal(12, 2)

  sale    Sale     @relation(fields: [saleId], references: [id], onDelete: Cascade)
  product Product? @relation(fields: [productId], references: [id])

  @@map("sale_items")
}

// ============================================================
// COMPRAS
// ============================================================

enum PurchaseStatus {
  PENDING   // pendiente de pago
  PAID      // pagada
  CANCELLED
}

model Purchase {
  id         String         @id @default(cuid())
  companyId  String         @map("company_id")
  supplierId String?        @map("supplier_id")
  userId     String         @map("user_id")
  number     Int
  date       DateTime       @default(now())
  status     PurchaseStatus @default(PAID)
  paid       Boolean        @default(true)
  paidAt     DateTime?      @map("paid_at")
  subtotal   Decimal        @db.Decimal(12, 2)
  total      Decimal        @db.Decimal(12, 2)
  notes      String?
  createdAt  DateTime       @default(now()) @map("created_at")
  updatedAt  DateTime       @updatedAt @map("updated_at")

  company     Company          @relation(fields: [companyId], references: [id])
  supplier    Supplier?        @relation(fields: [supplierId], references: [id])
  user        User             @relation(fields: [userId], references: [id])
  items       PurchaseItem[]
  accountsPay AccountPayable[]
  transaction Transaction[]
  requisition Requisition?

  @@unique([companyId, number])
  @@index([companyId, date])
  @@map("purchases")
}

model PurchaseItem {
  id          String  @id @default(cuid())
  purchaseId  String  @map("purchase_id")
  productId   String? @map("product_id")
  description String
  quantity    Decimal @db.Decimal(12, 3)
  unitCost    Decimal @map("unit_cost") @db.Decimal(12, 2)
  total       Decimal @db.Decimal(12, 2)

  purchase Purchase @relation(fields: [purchaseId], references: [id], onDelete: Cascade)
  product  Product? @relation(fields: [productId], references: [id])

  @@map("purchase_items")
}

// ============================================================
// FINANZAS
// ============================================================

enum TransactionType {
  INCOME
  EXPENSE
}

enum TransactionRefType {
  SALE
  PURCHASE
  ACCOUNT_RECEIVABLE
  ACCOUNT_PAYABLE
  MANUAL
}

model Transaction {
  id          String             @id @default(cuid())
  companyId   String             @map("company_id")
  type        TransactionType
  category    String
  amount      Decimal            @db.Decimal(12, 2)
  date        DateTime           @default(now())
  description String
  refType     TransactionRefType @map("ref_type") @default(MANUAL)
  refId       String?            @map("ref_id")
  saleId      String?            @map("sale_id")
  purchaseId  String?            @map("purchase_id")
  createdAt   DateTime           @default(now()) @map("created_at")

  company  Company   @relation(fields: [companyId], references: [id])
  sale     Sale?     @relation(fields: [saleId], references: [id])
  purchase Purchase? @relation(fields: [purchaseId], references: [id])

  @@index([companyId, date])
  @@index([companyId, type])
  @@map("transactions")
}

// ============================================================
// CUENTAS A COBRAR / PAGAR
// ============================================================

enum AccountStatus {
  PENDING
  PARTIAL
  PAID
}

model AccountReceivable {
  id          String        @id @default(cuid())
  companyId   String        @map("company_id")
  clientId    String        @map("client_id")
  saleId      String        @map("sale_id")
  amount      Decimal       @db.Decimal(12, 2)
  amountPaid  Decimal       @default(0) @map("amount_paid") @db.Decimal(12, 2)
  dueDate     DateTime?     @map("due_date")
  paidAt      DateTime?     @map("paid_at")
  status      AccountStatus @default(PENDING)
  notes       String?
  createdAt   DateTime      @default(now()) @map("created_at")
  updatedAt   DateTime      @updatedAt @map("updated_at")

  company Company @relation(fields: [companyId], references: [id])
  client  Client  @relation(fields: [clientId], references: [id])
  sale    Sale    @relation(fields: [saleId], references: [id])

  @@index([companyId, status])
  @@index([companyId, clientId])
  @@map("accounts_receivable")
}

model AccountPayable {
  id          String        @id @default(cuid())
  companyId   String        @map("company_id")
  supplierId  String        @map("supplier_id")
  purchaseId  String        @map("purchase_id")
  amount      Decimal       @db.Decimal(12, 2)
  amountPaid  Decimal       @default(0) @map("amount_paid") @db.Decimal(12, 2)
  dueDate     DateTime?     @map("due_date")
  paidAt      DateTime?     @map("paid_at")
  status      AccountStatus @default(PENDING)
  notes       String?
  createdAt   DateTime      @default(now()) @map("created_at")
  updatedAt   DateTime      @updatedAt @map("updated_at")

  company  Company  @relation(fields: [companyId], references: [id])
  supplier Supplier @relation(fields: [supplierId], references: [id])
  purchase Purchase @relation(fields: [purchaseId], references: [id])

  @@index([companyId, status])
  @@index([companyId, supplierId])
  @@map("accounts_payable")
}

// ============================================================
// AUDIT LOG
// ============================================================

model AuditLog {
  id        String   @id @default(cuid())
  companyId String   @map("company_id")
  entity    String   // 'sale' | 'purchase' | 'requisition' | 'quote'
  entityId  String   @map("entity_id")
  action    String   // 'created' | 'updated' | 'cancelled' | 'approved' | 'rejected' | ...
  userId    String   @map("user_id")
  userName  String   @map("user_name")
  data      Json?    // snapshot or diff
  createdAt DateTime @default(now()) @map("created_at")

  @@index([companyId, entity, entityId])
  @@index([companyId, createdAt])
  @@map("audit_logs")
}

// ============================================================
// SOLICITUDES DE COMPRA (REQUISITIONS)
// ============================================================

enum RequisitionStatus {
  DRAFT
  PENDING
  APPROVED
  REJECTED
  ORDERED
  CLOSED
}

enum RequisitionPriority {
  LOW
  NORMAL
  HIGH
  URGENT
}

model Requisition {
  id              String              @id @default(cuid())
  companyId       String              @map("company_id")
  requestedById   String              @map("requested_by_id")
  approvedById    String?             @map("approved_by_id")
  purchaseId      String?             @unique @map("purchase_id")
  projectId       String?             @map("project_id")
  number          Int
  title           String
  status          RequisitionStatus   @default(DRAFT)
  priority        RequisitionPriority @default(NORMAL)
  neededBy        DateTime?           @map("needed_by")
  rejectionReason String?             @map("rejection_reason")
  notes           String?
  createdAt       DateTime            @default(now()) @map("created_at")
  updatedAt       DateTime            @updatedAt @map("updated_at")

  company     Company           @relation(fields: [companyId], references: [id])
  requestedBy User              @relation("RequestedBy", fields: [requestedById], references: [id])
  approvedBy  User?             @relation("ApprovedBy", fields: [approvedById], references: [id])
  purchase    Purchase?         @relation(fields: [purchaseId], references: [id])
  project     Project?          @relation(fields: [projectId], references: [id])
  items       RequisitionItem[]

  @@unique([companyId, number])
  @@index([companyId, status])
  @@map("requisitions")
}

// ============================================================
// OBRAS / PROYECTOS
// ============================================================

model Project {
  id          String   @id @default(cuid())
  companyId   String   @map("company_id")
  name        String
  description String?  // descripción del proyecto/obra
  createdById String   @map("created_by_id")
  createdAt   DateTime @default(now()) @map("created_at")

  company      Company       @relation(fields: [companyId], references: [id])
  createdBy    User          @relation(fields: [createdById], references: [id])
  requisitions Requisition[]

  @@index([companyId, name])
  @@map("projects")
}

model RequisitionItem {
  id            String   @id @default(cuid())
  requisitionId String   @map("requisition_id")
  productId     String?  @map("product_id")
  description   String
  quantity      Decimal  @db.Decimal(12, 3)
  unit          String   @default("un")
  estimatedCost Decimal? @map("estimated_cost") @db.Decimal(12, 2)

  requisition Requisition @relation(fields: [requisitionId], references: [id], onDelete: Cascade)
  product     Product?    @relation(fields: [productId], references: [id])

  @@map("requisition_items")
}
